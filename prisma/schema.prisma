// ins-platform — insurance agency management system
// PostgreSQL 16 via @prisma/adapter-pg. All currency columns are
// Decimal -> NUMERIC(12,2) so sums stay exact.

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  // Prisma 7 forbids `url` in the schema; the connection string lives in
  // prisma.config.ts (CLI/Migrate) and in the PrismaPg adapter
  // (src/lib/prisma.ts) for the client. Both read env("DATABASE_URL").
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  PRODUCER
  CSR
  CLIENT
}

enum ClientType {
  INDIVIDUAL
  BUSINESS
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  FORMER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum OpportunityStage {
  NEW
  CONTACTED
  QUOTING
  PROPOSAL
  BOUND
  LOST
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  SYSTEM
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum LineOfBusiness {
  // ── Personal lines ──
  AUTO
  HOME
  RENTERS
  UMBRELLA
  LIFE
  HEALTH
  // Personal — added Wave A (additive)
  CONDO
  FLOOD
  MOTORCYCLE
  BOAT
  RV
  VALUABLE_ARTICLES
  PET
  IDENTITY_THEFT
  // ── Commercial lines ──
  GENERAL_LIABILITY
  COMMERCIAL_PROPERTY
  BOP
  WORKERS_COMP
  COMMERCIAL_AUTO
  CYBER
  // PROFESSIONAL is the legacy "Professional / E&O" value; keep it.
  // ERRORS_OMISSIONS is the explicit alias going forward.
  PROFESSIONAL
  INLAND_MARINE
  // Commercial — added Wave A (additive)
  ERRORS_OMISSIONS
  COMMERCIAL_UMBRELLA
  DIRECTORS_OFFICERS
  EPLI
  LIQUOR_LIABILITY
  SURETY_BONDS
  GARAGE
  BUILDERS_RISK
