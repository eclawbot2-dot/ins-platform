// ── Customer-appreciation / lifecycle-touchpoint engine ──────────────

/// A reusable, warm/professional outreach template. The evaluator scans
/// the book per active template and schedules ScheduledTouchpoint rows.
model TouchpointTemplate {
  id              String             @id @default(cuid())
  key             String             @unique
  name            String
  category        TouchpointCategory
  channel         TouchpointChannel  @default(EMAIL)
  triggerType     TouchpointTrigger
  offsetDays      Int                @default(0) // signed: -90 = 90 days before anchor
  holidayKey      String? // for HOLIDAY triggers → date table for the year
  tenureMonths    Int? // for TENURE_MILESTONE triggers
  subject         String
  body            String // text with {{merge}} fields
  audienceFilter  Json? // optional narrowing (status, type, lob…)
  active          Boolean            @default(true)
  requiresApproval Boolean           @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  scheduled ScheduledTouchpoint[]
}

/// A single scheduled/sent communication — this IS the communication log
/// (one table). The @unique idempotencyKey guarantees a given anchor is
/// never double-scheduled / double-sent across re-runs.
model ScheduledTouchpoint {
  id              String             @id @default(cuid())
  clientId        String
  client          Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  templateKey     String
  template        TouchpointTemplate @relation(fields: [templateKey], references: [key], onDelete: Cascade)
  channel         TouchpointChannel  @default(EMAIL)
  status          TouchpointStatus   @default(PENDING)
  scheduledFor    DateTime
  sentAt          DateTime?
  toAddress       String?
  renderedSubject String?
  renderedBody    String?
  relatedType     String? // "Policy" | "Invoice" | "Claim" | "Referral" …
  relatedId       String?
  idempotencyKey  String             @unique
  failureReason   String?
  approvedById    String?
  approvedBy      User?              @relation("TouchpointApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt       DateTime           @default(now())

  @@index([clientId, createdAt]) // 360 timeline
  @@index([status, scheduledFor]) // queue + send sweep
}

/// Per-client communication consent + channel preferences. CAN-SPAM /
/// opt-out is enforced in the ENGINE, not just the UI.
model ClientCommunicationPreferences {
  id               String            @id @default(cuid())
  clientId         String            @unique
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  doNotContact     Boolean           @default(false)
  optOnboarding    Boolean           @default(true)
  optRenewal       Boolean           @default(true)
  optPayment       Boolean           @default(true)
  optClaim         Boolean           @default(true)
  optAppreciation  Boolean           @default(true)
  optSatisfaction  Boolean           @default(true)
  optOffboarding   Boolean           @default(true)
  preferredChannel TouchpointChannel @default(EMAIL)
  quietHoursStart  Int               @default(8)
  quietHoursEnd    Int               @default(20)
  unsubscribeToken String            @unique @default(cuid())
  smsConsentAt     DateTime?
  updatedAt        DateTime          @updatedAt
}

// ── AI Compare / coverage-analysis tool ──────────────────────────────
// A single coverage-analysis run: someone (public visitor, portal
// client, or staff) submits a policy (uploaded dec page or keyed
// coverages); the pipeline extracts → summarizes → gap-analyzes →
// recommends. Degrades gracefully: with no ANTHROPIC_API_KEY the row is
// stored PENDING for staff review and the deterministic gap rules still
// power the gap report.

enum PolicyAnalysisSource {
  PUBLIC_UPLOAD // anonymous visitor via /compare (lead-gen funnel)
  CLIENT_PORTAL // authed portal client running a checkup on their policy
  STAFF // staff running analysis on a client's policy
}

enum PolicyAnalysisStatus {
  PENDING // submitted, awaiting extraction (e.g. no AI key yet)
  EXTRACTING // extraction in progress
  ANALYZED // summary + gaps + recommendations produced
  FAILED // extraction/analysis failed
  MANUAL_REVIEW // routed to staff to key coverages by hand
}

model PolicyAnalysis {
  id              String               @id @default(cuid())
  source          PolicyAnalysisSource
  status          PolicyAnalysisStatus @default(PENDING)

  // Submitter identity (public funnel) — null when authed.
  uploaderName    String?
  uploaderEmail   String?

  // Linked records when known.
  clientId        String?
  client          Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdById     String?
  createdBy       User?                @relation("PolicyAnalysisCreator", fields: [createdById], references: [id], onDelete: SetNull)
  // The lead this submission generated (public funnel).
  leadId          String?
  lead            Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Extracted / keyed policy facts.
  lineOfBusiness  LineOfBusiness?
  carrierName     String?

  // Pipeline outputs (JSON blobs kept opaque to the DB).
  extractedJson   Json?
  summaryText     String?
  gapsJson        Json?
  recommendationsJson Json?
  score           Int?

  // Stored upload (random name under uploads/, like Document.filePath).
  fileKey         String?
  fileName        String?

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([source, status])
  @@index([clientId])
  @@index([createdAt])
}

// ── Households (Wave D-final) ─────────────────────────────────────────
// A household groups related Clients (a family unit, or a primary insured
// + dependents). It powers a combined 360 view, de-duplicates the
// touchpoint engine (one greeting per household), and lets account-
// rounding cross-sell across every member's book.
model Household {
  id            String     @id @default(cuid())
  name          String
  notes         String?
  // Optional designated primary client (the household "head").
  primaryClientId String?
  primaryClient   Client?  @relation("HouseholdPrimary", fields: [primaryClientId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  members Client[]

  @@index([name])
}

// ── Surplus-lines compliance (Wave D-final) ───────────────────────────
// One filing record per surplus-lines policy. Surplus-lines (E&S) business
// is placed with non-admitted carriers and must be filed with the state's
// stamping office: surplus-lines tax + stamping fee are owed, and a
// diligent-search affidavit is usually required.
model SurplusLinesFiling {
  id                  String             @id @default(cuid())
  policyId            String             @unique
  policy              Policy             @relation(fields: [policyId], references: [id], onDelete: Cascade)
  state               String
  status              SurplusLinesStatus @default(PENDING)
  filingNumber        String?
  // Money owed to the state (Decimal — exact).
  surplusLinesTax     Decimal?           @db.Decimal(12, 2)
  stampingFee         Decimal?           @db.Decimal(12, 2)
  taxRatePct          Decimal?           @db.Decimal(6, 3)
  // Diligent-search / affidavit compliance.
  diligentSearchDone  Boolean            @default(false)
  affidavitOnFile     Boolean            @default(false)
  filedAt             DateTime?
  dueDate             DateTime?
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@index([state])
}

// ── Carrier appetite / eligibility-by-LOB (Wave D-final) ──────────────
// Per-carrier, per-LOB market-appetite rows. Producers use the market
// finder ("who writes CONDO in our area?") to pick markets: it joins this
// table with appointment status + commission schedule.
model CarrierAppetiteRow {
  id             String          @id @default(cuid())
  carrierId      String
  carrier        Carrier         @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  lineOfBusiness LineOfBusiness
  appetite       CarrierAppetite @default(STANDARD)
  // Optional geographic / class qualifiers.
  states         String? // comma-separated state codes; null = all appointed states
  classNotes     String? // "no coastal", "TIV < $5M", "ineligible: trampolines"
  minPremium     Decimal?        @db.Decimal(12, 2)
  maxPremium     Decimal?        @db.Decimal(12, 2)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([carrierId, lineOfBusiness])
  @@index([lineOfBusiness])
}

// ── E-signature (Wave D-final, deferred-API) ──────────────────────────
// A SignatureRequest is the agency-side envelope for getting a document
// signed (proposal / application / COI). It is provider-agnostic and
// DORMANT by default: with no provider configured (provider=MANUAL) the
// app produces a printable sign-here packet and lets staff manually mark
// it signed. The DOCUSIGN / DROPBOX_SIGN seams exist for a future wave —
// env-gated, like the AI / Xero adapters.
model SignatureRequest {
  id            String            @id @default(cuid())
  provider      SignatureProvider @default(MANUAL)
  status        SignatureStatus   @default(DRAFT)
  docKind       SignatureDocKind  @default(OTHER)
  title         String
  // Signer.
  signerName    String
  signerEmail   String
  // Optional linkage.
  clientId      String?
  client        Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  policyId      String?
  policy        Policy?           @relation(fields: [policyId], references: [id], onDelete: SetNull)
  // What we're signing (a stored doc, or a generated packet path).
  documentPath  String?
  message       String?
  // Provider envelope handle (null while MANUAL/dormant).
  envelopeId    String?
  // Lifecycle stamps.
  sentAt        DateTime?
  viewedAt      DateTime?
  signedAt      DateTime?
  declinedAt    DateTime?
  voidedAt      DateTime?
  expiresAt     DateTime?
  declineReason String?
  createdById   String?
  createdBy     User?             @relation("SignatureRequestCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([policyId])
}

// NOTE: Group / employee-benefits was intentionally removed. Tabor does
// NOT write company/group employee benefits — the platform stays out of
// that line. (Personal LIFE / HEALTH P&C lines are unaffected.)
