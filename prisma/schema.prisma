enum PolicyStatus {
  QUOTE
  BOUND
  ACTIVE
  RENEWED
  CANCELLED
  EXPIRED
  NON_RENEWED
}

enum BillingType {
  AGENCY_BILL
  DIRECT_BILL
}

enum QuoteRequestStatus {
  OPEN
  QUOTED
  PRESENTED
  BOUND
  LOST
}

enum QuoteStatus {
  DRAFT
  SUBMITTED
  RECEIVED
  PRESENTED
  ACCEPTED
  DECLINED
}

enum RenewalStatus {
  PENDING_REVIEW
  REMARKETING
  QUOTED
  RENEWED
  LOST
}

enum ClaimStatus {
  REPORTED
  OPEN
  UNDER_REVIEW
  APPROVED
  DENIED
  CLOSED
}

enum AppointmentStatus {
  APPOINTED
  PENDING
  TERMINATED
  NOT_APPOINTED
}

enum StatementStatus {
  DRAFT
  RECONCILING
  RECONCILED
}

enum MatchStatus {
  UNMATCHED
  MATCHED
  VARIANCE
}

enum TransactionType {
  NEW_BUSINESS
  RENEWAL
  ENDORSEMENT
  CANCELLATION
  AUDIT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  VOID
}

enum DocType {
  POLICY_DOC
  APPLICATION
  ENDORSEMENT
  CERTIFICATE
  CLAIM_DOC
  CORRESPONDENCE
  ID_CARD
  EOI
  LOSS_RUN
  OTHER
}

// ── Servicing artifacts (Wave B) ─────────────────────────────────────

// Evidence of Property (ACORD 27/28-style) issuance — the property
// analogue of the COI/Certificate. A lender/mortgagee "holder" + the
// dwelling/property limits snapshotted at issuance.
enum EoiKind {
  EVIDENCE_OF_PROPERTY // ACORD 27 — personal / residential
  EVIDENCE_COMMERCIAL // ACORD 28 — commercial property
}

enum EoiHolderInterest {
  MORTGAGEE
  LOSS_PAYEE
  ADDITIONAL_INTEREST
  LENDER
}

enum EndorsementRequestType {
  ADD_VEHICLE
  REMOVE_VEHICLE
  ADD_DRIVER
  REMOVE_DRIVER
  CHANGE_LIMIT
  ADD_LIENHOLDER
  REMOVE_LIENHOLDER
  ADDRESS_CHANGE
  ADD_COVERAGE
  REMOVE_COVERAGE
  OTHER
}

enum EndorsementRequestStatus {
  REQUESTED
  IN_REVIEW
  SUBMITTED_TO_CARRIER
  COMPLETED
  DECLINED
}

enum EndorsementRequestSource {
  STAFF
  PORTAL
}

// ── Customer-appreciation / lifecycle-touchpoint engine ──────────────

enum TouchpointCategory {
  ONBOARDING
  RENEWAL
  PAYMENT
  CLAIM
  APPRECIATION
  SATISFACTION
  OFFBOARDING
}

enum TouchpointChannel {
  EMAIL
  SMS // dormant — SMS gated on smsConsentAt + quiet hours
}

enum TouchpointTrigger {
  RENEWAL_RELATIVE
  PAYMENT_DUE_RELATIVE
  BIRTHDAY
  POLICY_ANNIVERSARY
  HOLIDAY
  TENURE_MILESTONE
  LIFECYCLE_EVENT
  MANUAL
}

enum TouchpointStatus {
  PENDING
  APPROVED
  SENT
  SKIPPED
  FAILED
}

model EvidenceOfProperty {
  id              String            @id @default(cuid())
  eoiNumber       String            @unique
  kind            EoiKind           @default(EVIDENCE_OF_PROPERTY)
  clientId        String
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  policyId        String
  policy          Policy            @relation(fields: [policyId], references: [id], onDelete: Cascade)
  // Snapshot of policy/carrier at issuance (the ACORD way).
  carrierName     String
  policyNumber    String
  effectiveDate   DateTime
  expirationDate  DateTime
  // Property snapshot.
  propertyAddress String?
  coverageALimit  Decimal?          @db.Decimal(14, 2)
  deductibleText  String?
  // Lender / mortgagee holder.
  holderName      String
  holderInterest  EoiHolderInterest @default(MORTGAGEE)
  holderAddress   String?
  loanNumber      String?
  remarks         String?
  issuedAt        DateTime          @default(now())
  issuedById      String
  issuedBy        User              @relation(fields: [issuedById], references: [id])

  @@index([clientId])
  @@index([policyId])
}

model EndorsementRequest {
  id            String                   @id @default(cuid())
  policyId      String
  policy        Policy                   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  requestType   EndorsementRequestType   @default(OTHER)
  status        EndorsementRequestStatus @default(REQUESTED)
  source        EndorsementRequestSource @default(STAFF)
  // Structured detail — free-form summary plus an effective date the
  // change should take. The realized Endorsement (once processed) links
  // back here.
  summary       String
  payload       String? // optional JSON blob of typed fields
  effectiveDate DateTime?
  notes         String?
  // Who asked: a staff user OR a portal client user.
  requestedById String?
  requestedBy   User?                    @relation("EndorsementRequestRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  // Who processed it (staff).
  processedById String?
  processedBy   User?                    @relation("EndorsementRequestProcessor", fields: [processedById], references: [id], onDelete: SetNull)
  endorsementId String?                  @unique
  endorsement   Endorsement?             @relation(fields: [endorsementId], references: [id], onDelete: SetNull)
  declineReason String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([status])
  @@index([policyId])
}

// Reinstatement record — restoring a CANCELLED policy to ACTIVE.
model Reinstatement {
  id              String   @id @default(cuid())
  policyId        String
  policy          Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  cancelledAt     DateTime
  reinstatedAt    DateTime
  lapseDays       Int      @default(0)
  reason          String
  lapseHandling   String? // "no lapse in coverage" / "gap excluded" …
  reinstatedById  String?
  reinstatedBy    User?    @relation(fields: [reinstatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([policyId])
}

enum LicenseClass {
  PROPERTY_CASUALTY
  LIFE_HEALTH
  PERSONAL_LINES
  SURPLUS_LINES
  ADJUSTER
}

enum CampaignChannel {
  REFERRAL
  WEB
  SOCIAL
  EMAIL
  DIRECT_MAIL
  EVENT
  PAID_SEARCH
  OTHER
}

enum IntegrationProvider {
  XERO
}

// ── Wave D-final: household / surplus-lines / appetite / e-sign

enum HouseholdRole {
  PRIMARY
  SPOUSE
  PARTNER
  CHILD
  PARENT
  DEPENDENT
  OTHER
}

enum SurplusLinesStatus {
  PENDING // policy is surplus-lines but not yet filed
  FILED // filing submitted to the state stamping office
  EXEMPT // exempt from filing (e.g. industrial-insured exemption)
  VOID
}

enum CarrierAppetite {
  PREFERRED // actively wants this risk
  STANDARD // will write it
  RESTRICTED // case-by-case / referral
  DECLINE // will not write
}

enum SignatureProvider {
  MANUAL // no e-sign provider configured — print + wet-sign / manual mark
  DOCUSIGN // dormant adapter seam
  DROPBOX_SIGN // dormant adapter seam
}

enum SignatureStatus {
  DRAFT
  SENT // envelope dispatched to signer(s)
  VIEWED
  SIGNED // all signers complete
  DECLINED
  VOIDED
  EXPIRED
}

enum SignatureDocKind {
  PROPOSAL
  APPLICATION
  COI
  EOI
  POLICY_DOC
  OTHER
}

enum ConnectionStatus {
  CONNECTED
  TOKEN_EXPIRED
  ERROR
  DISCONNECTED
}

enum SyncStatus {
  RUNNING
  OK
  FAILED
  PARTIAL
}

// ── Auth / users ─────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  password          String
  role              Role      @default(CSR)
  active            Boolean   @default(true)
  phone             String?
  npn               String?
  defaultSplitPct   Decimal   @default(100) @db.Decimal(5, 2)
  lastLoginAt       DateTime?
  sessionsRevokedAt DateTime?
  // Set only for role CLIENT — links a portal login to its Client record.
  clientId          String?
  client            Client?   @relation("ClientPortalUsers", fields: [clientId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  resetTokens        PasswordResetToken[]
  portalInvites      PortalInvite[]
  licenses           License[]
  producedPolicies   Policy[]             @relation("PolicyProducer")
  servicedPolicies   Policy[]             @relation("PolicyCsr")
  producedClients    Client[]             @relation("ClientProducer")
  servicedClients    Client[]             @relation("ClientCsr")
  assignedLeads      Lead[]
  opportunities      Opportunity[]
  activities         Activity[]
  assignedTasks      Task[]               @relation("TaskAssignee")
  createdTasks       Task[]               @relation("TaskCreator")
  quoteRequests      QuoteRequest[]
  renewals           Renewal[]
  splits             PolicyProducerSplit[]
  issuedCertificates Certificate[]
  issuedEois         EvidenceOfProperty[]
  requestedEndorsements EndorsementRequest[] @relation("EndorsementRequestRequester")
  processedEndorsements EndorsementRequest[] @relation("EndorsementRequestProcessor")
  reinstatements     Reinstatement[]
  documents          Document[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  approvedTouchpoints ScheduledTouchpoint[] @relation("TouchpointApprover")
  policyAnalyses     PolicyAnalysis[]       @relation("PolicyAnalysisCreator")
  signatureRequests  SignatureRequest[]     @relation("SignatureRequestCreator")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// Client-portal invitation. Like PasswordResetToken, only the SHA-256
// hash of the raw token is stored. 7-day expiry, single-use, revocable.
model PortalInvite {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  email       String
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  expiresAt   DateTime
  usedAt      DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([clientId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorEmail String?
  action     String
  entityType String?
  entityId   String?
  detail     String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}

// ── Agency settings ──────────────────────────────────────────────────

model AgencyProfile {
  id            String   @id @default("agency")
  name          String   @default("Tabor Agency")
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  zip           String?
  phone         String?
  email         String?
  website       String?
  licenseNumber String?
  updatedAt     DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  subject   String
  body      String
  updatedAt DateTime @updatedAt
}

model LeadIntakeKey {
  id         String    @id @default(cuid())
  label      String
  key        String    @unique
  active     Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

// ── CRM ──────────────────────────────────────────────────────────────

model Client {
  id           String       @id @default(cuid())
  type         ClientType   @default(INDIVIDUAL)
  status       ClientStatus @default(PROSPECT)
  name         String
  firstName    String?
  lastName     String?
  businessName String?
  email        String?
  phone        String?
  preferredName String?     // warm salutation used in lifecycle touchpoints
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zip          String?
  dateOfBirth  DateTime?
  industry     String?
  source       String?
  notes        String?
  // Household this client belongs to (related family/members share a 360).
  householdId  String?
  household    Household?   @relation(fields: [householdId], references: [id], onDelete: SetNull)
  householdRole HouseholdRole @default(OTHER)
  producerId   String?
  producer     User?        @relation("ClientProducer", fields: [producerId], references: [id], onDelete: SetNull)
  csrId        String?
  csr          User?        @relation("ClientCsr", fields: [csrId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  contacts      Contact[]
  leads         Lead[]
  opportunities Opportunity[]
  policies      Policy[]
  quoteRequests QuoteRequest[]
  claims        Claim[]
  invoices      Invoice[]
  documents     Document[]
  activities    Activity[]
  tasks         Task[]
  certificates  Certificate[]
  eois          EvidenceOfProperty[]
  referrals     Referral[]
  portalUsers   User[]         @relation("ClientPortalUsers")
  portalInvites PortalInvite[]
  priorPolicies PriorPolicy[]
  // Customer-appreciation / lifecycle-touchpoint engine.
  scheduledTouchpoints ScheduledTouchpoint[]
  commPrefs            ClientCommunicationPreferences?
  // AI Compare / coverage-analysis tool.
  policyAnalyses       PolicyAnalysis[]
  // Wave D-final.
  primaryOfHousehold   Household[]    @relation("HouseholdPrimary")
  signatureRequests    SignatureRequest[]

  @@index([name])
  @@index([status])
  @@index([householdId])
}

// ── X-date capture (Wave A) ──────────────────────────────────────────
// Competitor / prior-carrier policy data on a prospect or existing
// client. The `expirationDate` is the X-date: the cross-sell / win-back
// trigger. Many per client or lead.
model PriorPolicy {
  id             String         @id @default(cuid())
  clientId       String?
  client         Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  lineOfBusiness LineOfBusiness
  currentCarrier String?
  currentPremium Decimal?       @db.Decimal(12, 2)
  expirationDate DateTime // the X-date
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([expirationDate])
  @@index([clientId])
  @@index([leadId])
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  title     String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Lead {
  id             String          @id @default(cuid())
  firstName      String
  lastName       String
  email          String?
  phone          String?
  zip            String?
  lineOfBusiness LineOfBusiness?
  message        String?
  source         String?
  status         LeadStatus      @default(NEW)
  score          Int             @default(0)
  assignedToId   String?
  assignedTo     User?           @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  campaignId     String?
  campaign       Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  clientId       String?
  client         Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  opportunities Opportunity[]
  quoteRequests QuoteRequest[]
  activities    Activity[]
  tasks         Task[]
  referrals     Referral[]
  priorPolicies PriorPolicy[]
  policyAnalyses PolicyAnalysis[]

  @@index([status])
  @@index([createdAt])
}

model Opportunity {
  id                String           @id @default(cuid())
  name              String
  stage             OpportunityStage @default(NEW)
  lineOfBusiness    LineOfBusiness
  premiumEstimate   Decimal?         @db.Decimal(12, 2)
  expectedCloseDate DateTime?
  lostReason        String?
  clientId          String?
  client            Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadId            String?
  lead              Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  ownerId           String
  owner             User             @relation(fields: [ownerId], references: [id])
  boundPolicyId     String?          @unique
  boundPolicy       Policy?          @relation(fields: [boundPolicyId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  activities Activity[]

  @@index([stage])
}

model Activity {
  id            String       @id @default(cuid())
  type          ActivityType @default(NOTE)
  subject       String
  body          String?
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  policyId      String?
  policy        Policy?      @relation(fields: [policyId], references: [id], onDelete: Cascade)
  claimId       String?
  claim         Claim?       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@index([createdAt])
  @@index([clientId])
}

model Task {
  id           String       @id @default(cuid())
  title        String
  detail       String?
  dueDate      DateTime
  status       TaskStatus   @default(OPEN)
  priority     TaskPriority @default(NORMAL)
  assignedToId String?
  assignedTo   User?        @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  clientId     String?
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId       String?
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  policyId     String?
  policy       Policy?      @relation(fields: [policyId], references: [id], onDelete: Cascade)
  claimId      String?
  claim        Claim?       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  renewalId    String?
  renewal      Renewal?     @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status, dueDate])
  @@index([assignedToId])
}

// ── Carriers ─────────────────────────────────────────────────────────

model Carrier {
  id                   String            @id @default(cuid())
  name                 String            @unique
  naicCode             String?
  amBestRating         String?
  portalUrl            String?
  phone                String?
  paymentTermsDays     Int               @default(30)
  appointmentStatus    AppointmentStatus @default(NOT_APPOINTED)
  appointedAt          DateTime?
  appointmentExpiresAt DateTime?
  isMga                Boolean           @default(false)
  notes                String?
  // Wave D-final: underwriting guidelines + binding authority.
  uwGuidelinesUrl      String?
  uwGuidelinesNotes    String?
  bindingAuthorityNotes String?
  // Max single-risk premium/limit we can bind without carrier referral.
  bindingAuthorityLimit Decimal?         @db.Decimal(14, 2)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  contacts   CarrierContact[]
  schedules  CommissionSchedule[]
  appetites  CarrierAppetiteRow[]
  policies   Policy[]
  quotes     Quote[]
  statements CommissionStatement[]
}

model CarrierContact {
  id        String  @id @default(cuid())
  carrierId String
  carrier   Carrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  name      String
  role      String?
  email     String?
  phone     String?
}

model CommissionSchedule {
  id             String         @id @default(cuid())
  carrierId      String
  carrier        Carrier        @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  lineOfBusiness LineOfBusiness
  newPct         Decimal        @db.Decimal(5, 2)
  renewalPct     Decimal        @db.Decimal(5, 2)

  @@unique([carrierId, lineOfBusiness])
}

// ── Policies ─────────────────────────────────────────────────────────

model Policy {
  id                 String         @id @default(cuid())
  policyNumber       String         @unique
  clientId           String
  client             Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  carrierId          String
  carrier            Carrier        @relation(fields: [carrierId], references: [id])
  mga                String?
  lineOfBusiness     LineOfBusiness
  status             PolicyStatus   @default(QUOTE)
  billingType        BillingType    @default(DIRECT_BILL)
  premium            Decimal        @db.Decimal(12, 2)
  commissionRatePct  Decimal        @db.Decimal(5, 2)
  commissionAmount   Decimal        @db.Decimal(12, 2)
  isNewBusiness      Boolean        @default(true)
  effectiveDate      DateTime
  expirationDate     DateTime
  boundAt            DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  producerId         String
  producer           User           @relation("PolicyProducer", fields: [producerId], references: [id])
  csrId              String?
  csr                User?          @relation("PolicyCsr", fields: [csrId], references: [id], onDelete: SetNull)
  renewalOfId        String?
  renewalOf          Policy?        @relation("PolicyRenewalChain", fields: [renewalOfId], references: [id], onDelete: SetNull)
  renewedBy          Policy[]       @relation("PolicyRenewalChain")
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  endorsements         Endorsement[]
  claims               Claim[]
  renewals             Renewal[]
  splits               PolicyProducerSplit[]
  certificates         Certificate[]
  certificateCoverages CertificateCoverage[]
  invoices             Invoice[]
  documents            Document[]
  activities           Activity[]
  tasks                Task[]
  statementLines       CommissionStatementLine[]
  boundFromQuote       Quote?                    @relation("QuoteBoundPolicy")
  boundFromOpportunity Opportunity?
  // Wave A: coverage schedule + line-specific risk items.
  coverages            Coverage[]
  vehicles             Vehicle[]
  drivers              Driver[]
  dwellings            Dwelling[]
  scheduledItems       ScheduledItem[]
  watercraft           Watercraft[]
  locations            InsuredLocation[]
