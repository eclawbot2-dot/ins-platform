# ── Core ─────────────────────────────────────────────────────────────
# PostgreSQL 16 — database `ins` must exist (see RUNBOOK.md)
DATABASE_URL="postgresql://ins:ins_dev@127.0.0.1:5432/ins?schema=public"

# NextAuth — generate with `openssl rand -base64 32`
AUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="https://ins.jahdev.com"
APP_URL="https://ins.jahdev.com"
AUTH_TRUST_HOST=true

# ── Email (Resend) ───────────────────────────────────────────────────
# When EMAIL_TRANSPORT is unset (or "log"), emails are logged only —
# nothing is actually sent. Set EMAIL_TRANSPORT=resend + RESEND_API_KEY
# once the ins.jahdev.com domain is verified in Resend.
# NEVER use braetr.com as the sender for this app.
EMAIL_TRANSPORT="log"
RESEND_API_KEY=""
EMAIL_FROM="no-reply@ins.jahdev.com"

# ── Public lead intake API ───────────────────────────────────────────
# POST /api/public/leads must carry header X-Lead-Key matching this.
LEAD_INTAKE_KEY="ins-lead-intake-2026"

# ── Xero (Accounting integration) ────────────────────────────────────
# Create an app at https://developer.xero.com/app/manage and register
# redirect URI: https://ins.jahdev.com/api/integrations/xero/callback
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""

# ── Google Workspace (service account + domain-wide delegation) ─────
# Path to the SA key JSON. The file does not need to exist for the app
# to run — Workspace features degrade to "not configured".
GOOGLE_WORKSPACE_SA_KEY_FILE="C:/Users/bot/secrets/ins-workspace-sa.json"
# The Workspace user the service account impersonates (DWD subject).
GOOGLE_WORKSPACE_SUBJECT=""

# ── Client portal ────────────────────────────────────────────────────
# Public base URL used in client-facing emails/links (portal invites).
# The portal answers on BOTH hostnames; once taboragency.com NS cuts
# over, point this at the vanity host:
#   PORTAL_URL="https://portal.taboragency.com"
PORTAL_URL="https://ins.jahdev.com"
