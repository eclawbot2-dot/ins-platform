# ── Core ─────────────────────────────────────────────────────────────
# PostgreSQL 16 — database `ins` must exist (see RUNBOOK.md)
DATABASE_URL="postgresql://ins:ins_dev@127.0.0.1:5432/ins?schema=public"

# NextAuth — generate with `openssl rand -base64 32`
AUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="https://ins.jahdev.com"
APP_URL="https://ins.jahdev.com"
AUTH_TRUST_HOST=true

# ── Email ────────────────────────────────────────────────────────────
# EMAIL_TRANSPORT selects the outbound path:
#   gmail  — Gmail API users.messages.send via the Workspace service
#            account (domain-wide delegation), impersonating the real
#            mailbox in GMAIL_SENDER_SUBJECT. Mail leaves from the actual
#            taboragency.com domain and lands in that mailbox's Sent.
#            Requires GOOGLE_WORKSPACE_SA_KEY_FILE + GMAIL_SENDER_SUBJECT;
#            the SA client ID must be authorized for the gmail.send scope
#            in the taboragency.com Admin console (Security → API controls
#            → Domain-wide Delegation). If the grant is missing/403, the
#            transport logs the exact fix and falls back to resend (when
#            RESEND_API_KEY is set), else log-only.
#   resend — Resend HTTP API (requires a Resend-verified sender domain).
#   log / unset — logged only, nothing is actually sent.
# NEVER use braetr.com as the sender for this app.
EMAIL_TRANSPORT="log"
RESEND_API_KEY=""
EMAIL_FROM="Tabor Agency <no-reply@taboragency.com>"

# ── Public lead intake API ───────────────────────────────────────────
# POST /api/public/leads must carry header X-Lead-Key matching this.
LEAD_INTAKE_KEY="ins-lead-intake-2026"

# ── Touchpoint engine (customer-appreciation / lifecycle) ────────────
# POST /api/cron/touchpoints must carry header X-Cron-Key matching this.
# Generate with `openssl rand -hex 24`. If unset, the cron route 503s
# safely and never runs unauthenticated. A daily Task Scheduler job
# (ins-touchpoints) hits the route ~07:00 — see RUNBOOK.md.
CRON_KEY=""
# Dormant AI personalization (CLUSTER F). Both must be set to activate;
# with no key the engine runs entirely on the seeded templates.
ANTHROPIC_API_KEY=""
TOUCHPOINT_AI=""

# ── Xero (Accounting integration) ────────────────────────────────────
# Create an app at https://developer.xero.com/app/manage and register
# redirect URI: https://ins.jahdev.com/api/integrations/xero/callback
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""

# ── Google Workspace (service account + domain-wide delegation) ─────
# Path to the SA key JSON (the shared gcon-workspace platform SA). The
# file does not need to exist for the app to run — Workspace features
# degrade to "not configured".
GOOGLE_WORKSPACE_SA_KEY_FILE="C:/Users/bot/secrets/gcon-workspace-sa.json"
# The Workspace user the service account impersonates (DWD subject).
GOOGLE_WORKSPACE_SUBJECT=""
# Mailbox the EMAIL_TRANSPORT=gmail path impersonates for sending. The
# EMAIL_FROM address is passed through as the From header — Gmail honors
# it only when it is this user or one of their registered send-as
# aliases (anything else is rewritten by Gmail to the authenticated
# user). Unparseable EMAIL_FROM falls back to this address.
GMAIL_SENDER_SUBJECT="b@taboragency.com"

# ── Client portal ────────────────────────────────────────────────────
# Public base URL used in client-facing emails/links (portal invites).
# The portal answers on BOTH hostnames; once taboragency.com NS cuts
# over, point this at the vanity host:
#   PORTAL_URL="https://portal.taboragency.com"
PORTAL_URL="https://ins.jahdev.com"
